# Smile Identity API Credentials
# Get your credentials from https://portal.smileidentity.com/
SMILE_PARTNER_ID=your_partner_id_here
SMILE_API_KEY=your_api_key_here
SMILE_SID_SERVER=0

# Server Configuration
SERVER_PORT=4567

# Notes:
# - SMILE_SID_SERVER: Use '0' for sandbox/testing, '1' for production
# - Copy this file to .env and replace the placeholder values with your actual credentials
